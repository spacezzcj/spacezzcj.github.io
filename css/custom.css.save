.recommend-card{
  background: rgba(0,255,180,.12);
  border: 2px solid #00ffb4;
  border-radius: 15px;
  padding: 20px;
  margin: 20px 0;
}

.stats-card{
  background: rgba(0,180,255,.12);
  border: 2px solid #00b4ff;
  border-radius: 15px;
  padding: 20px;
  margin: 20px 0;
}

.worldcup-card{
  background: rgba(255,215,0,.12);
  border: 2px solid #ffd700;
  border-radius: 15px;
  padding: 20px;
  margin: 20px 0;
}.register-btn{
  display:block;
  text-align:center;
  background:#00ffb4;
  color:#000 !important;
  font-size:18px;
  font-weight:bold;
  padding:12px;
  border-radius:10px;
  margin:15px 0 30px;
  text-decoration:none !important;
}

.register-btn:hover{
  transform:scale(1.03);
}


